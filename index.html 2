   background: form.type === t ? t === 'Entrada' ? '#4CAF8222' : '#e0505022' : 'transparent',\n              border: `1px solid ${form.type === t ? t === 'Entrada' ? '#4CAF82' : '#e05050' : BORDER}`,\n              color: form.type === t ? t === 'Entrada' ? '#4CAF82' : '#e05050' : MUTED\n            }}>\n                  <Icon name={t === 'Entrada' ? 'arrow_up' : 'arrow_down'} size={14} color={form.type === t ? t === 'Entrada' ? '#4CAF82' : '#e05050' : MUTED} />\n                  {t}\n                <\u002Fbutton>\n            )}\n            <\u002Fdiv>\n          <\u002FField>\n          <Field label=\"Descrição\">\n            <input value={form.descricao} onChange={(e) => setForm({ ...form, descricao: e.target.value })}\n          placeholder=\"Ex: Pagamento cliente, Aluguel...\" style={{ ...inputStyle, border: \"1px solid rgb(36, 36, 36)\" }}\n          onFocus={(e) => e.target.style.borderColor = WINE}\n          onBlur={(e) => e.target.style.borderColor = BORDER} />\n          \n          <\u002FField>\n          <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 16 }}>\n            <Field label=\"Valor (R$)\">\n              <input type=\"number\" value={form.value} onChange={(e) => setForm({ ...form, value: e.target.value })}\n            placeholder=\"0,00\" style={{ ...inputStyle, border: \"1px solid rgb(36, 36, 36)\" }}\n            onFocus={(e) => e.target.style.borderColor = WINE}\n            onBlur={(e) => e.target.style.borderColor = BORDER} />\n            \n            <\u002FField>\n            <Field label=\"Data\">\n              <input type=\"date\" value={form.date} onChange={(e) => setForm({ ...form, date: e.target.value })}\n            style={inputStyle}\n            onFocus={(e) => e.target.style.borderColor = WINE}\n            onBlur={(e) => e.target.style.borderColor = BORDER} />\n            \n            <\u002FField>\n          <\u002Fdiv>\n          <div style={{ display: 'flex', justifyContent: 'flex-end', gap: 12, marginTop: 8 }}>\n            <Btn variant=\"ghost\" onClick={() => setModal(null)}>Cancelar<\u002FBtn>\n            <Btn onClick={save_} disabled={!form.descricao.trim() || !form.value}>\n              <Icon name=\"check\" size={14} /> Salvar\n            <\u002FBtn>\n          <\u002Fdiv>\n        <\u002FModal>\n      }\n    <\u002Fdiv>);\n\n}\n\n/* ─── RESPONSIVE HOOK ───────────────────────── */\nfunction useIsMobile() {\n  const [mobile, setMobile] = useState(() => window.innerWidth < 768);\n  useEffect(() => {\n    const fn = () => setMobile(window.innerWidth < 768);\n    window.addEventListener('resize', fn);\n    return () => window.removeEventListener('resize', fn);\n  }, []);\n  return mobile;\n}\n\n/* ─── HAMBURGER ICON ────────────────────────── */\nconst HamburgerIcon = ({ open, size = 20, color = 'currentColor' }) => open\n  ? <svg width={size} height={size} viewBox=\"0 0 24 24\" fill=\"none\" stroke={color} strokeWidth=\"2\" strokeLinecap=\"round\"><line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"/><\u002Fsvg>\n  : <svg width={size} height={size} viewBox=\"0 0 24 24\" fill=\"none\" stroke={color} strokeWidth=\"2\" strokeLinecap=\"round\"><line x1=\"3\" y1=\"6\" x2=\"21\" y2=\"6\"/><line x1=\"3\" y1=\"12\" x2=\"21\" y2=\"12\"/><line x1=\"3\" y1=\"18\" x2=\"21\" y2=\"18\"/><\u002Fsvg>;\n\n/* ─── COLLAPSE ICON ─────────────────────────── */\nconst CollapseIcon = ({ collapsed }) => (\n  <svg width={16} height={16} viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\" strokeLinecap=\"round\">\n    {collapsed\n      ? <><polyline points=\"9 18 15 12 9 6\"/><\u002F>\n      : <><polyline points=\"15 18 9 12 15 6\"/><\u002F>}\n  <\u002Fsvg>\n);\n\n/* ─── SIDEBAR ───────────────────────────────── */\nconst NAV = [\n  { id: 'dashboard', label: 'Dashboard', icon: 'dashboard' },\n  { id: 'services', label: 'Serviços', icon: 'services' },\n  { id: 'cash', label: 'Gestão de Caixa', icon: 'cash' },\n];\n\nfunction Sidebar({ active, setActive, onLogout, collapsed, setCollapsed, mobileOpen, setMobileOpen, isMobile }) {\n  const width = isMobile ? 240 : (collapsed ? 64 : 240);\n  const visible = isMobile ? mobileOpen : true;\n\n  const handleNav = (id) => {\n    setActive(id);\n    if (isMobile) setMobileOpen(false);\n  };\n\n  return (\n    <>\n      {/* Mobile overlay backdrop */}\n      {isMobile && mobileOpen && (\n        <div onClick={() => setMobileOpen(false)} style={{\n          position: 'fixed', inset: 0, background: 'rgba(0,0,0,0.7)',\n          zIndex: 99, backdropFilter: 'blur(2px)',\n        }} />\n      )}\n\n      <div style={{\n        width, minHeight: '100vh', background: '#0D0D0D',\n        borderRight: `1px solid ${BORDER}`, display: 'flex',\n        flexDirection: 'column',\n        position: 'fixed', left: 0, top: 0, bottom: 0, zIndex: 100,\n        transform: isMobile ? (mobileOpen ? 'translateX(0)' : 'translateX(-100%)') : 'translateX(0)',\n        transition: 'width 0.25s ease, transform 0.28s cubic-bezier(0.4,0,0.2,1)',\n        overflow: 'hidden',\n      }}>\n        {/* Logo + collapse toggle */}\n        <div style={{\n          padding: collapsed && !isMobile ? '28px 0 24px' : '28px 24px 24px',\n          borderBottom: `1px solid ${BORDER}`,\n          display: 'flex', alignItems: 'center',\n          justifyContent: collapsed && !isMobile ? 'center' : 'space-between',\n        }}>\n          {(!collapsed || isMobile) && (\n            <div>\n              <div style={{ fontSize: 26, fontWeight: 800, letterSpacing: '-0.02em' }}>\n                <span style={{ color: TEXT }}>NODE<\u002Fspan><span style={{ color: WINE }}>X<\u002Fspan>\n              <\u002Fdiv>\n              <div style={{ color: MUTED, letterSpacing: '0.18em', textTransform: 'uppercase', marginTop: 2, fontSize: 9 }}>Marketing Digital<\u002Fdiv>\n            <\u002Fdiv>\n          )}\n          {collapsed && !isMobile && (\n            <div style={{ fontSize: 20, fontWeight: 800 }}>\n              <span style={{ color: TEXT }}>N<\u002Fspan><span style={{ color: WINE }}>X<\u002Fspan>\n            <\u002Fdiv>\n          )}\n          {!isMobile && (\n            <button onClick={() => setCollapsed(!collapsed)} style={{\n              ...btnBase, background: 'transparent', color: MUTED, padding: 6,\n              border: `1px solid ${BORDER}`, borderRadius: 7,\n            }}>\n              <CollapseIcon collapsed={collapsed} />\n            <\u002Fbutton>\n          )}\n          {isMobile && (\n            <button onClick={() => setMobileOpen(false)} style={{\n              ...btnBase, background: 'transparent', color: MUTED, padding: 6,\n              border: `1px solid ${BORDER}`, borderRadius: 7,\n            }}>\n              <HamburgerIcon open={true} size={16} color={MUTED} />\n            <\u002Fbutton>\n          )}\n        <\u002Fdiv>\n\n        {/* Nav */}\n        <nav style={{ flex: 1, padding: collapsed && !isMobile ? '16px 8px' : '16px 12px' }}>\n          {NAV.map((n) => {\n            const isActive = active === n.id;\n            return (\n              <button key={n.id} onClick={() => handleNav(n.id)} style={{\n                ...btnBase, width: '100%',\n                justifyContent: collapsed && !isMobile ? 'center' : 'flex-start',\n                padding: collapsed && !isMobile ? '12px' : '11px 14px',\n                marginBottom: 4, borderRadius: 10, fontSize: 14,\n                background: isActive ? `${WINE}22` : 'transparent',\n                color: isActive ? TEXT : MUTED,\n                border: isActive ? `1px solid ${WINE}44` : '1px solid transparent',\n                position: 'relative',\n              }} title={collapsed && !isMobile ? n.label : undefined}>\n                {isActive && !collapsed && (\n                  <div style={{ position: 'absolute', left: 0, top: '20%', bottom: '20%', width: 3, background: WINE, borderRadius: '0 2px 2px 0' }} />\n                )}\n                <Icon name={n.icon} size={16} color={isActive ? WINE : MUTED} />\n                {(!collapsed || isMobile) && n.label}\n              <\u002Fbutton>\n            );\n          })}\n        <\u002Fnav>\n\n        {/* Logout */}\n        <div style={{ padding: collapsed && !isMobile ? '16px 8px' : '16px 12px', borderTop: `1px solid ${BORDER}` }}>\n          <button onClick={onLogout} style={{\n            ...btnBase, width: '100%',\n            justifyContent: collapsed && !isMobile ? 'center' : 'flex-start',\n            padding: collapsed && !isMobile ? '12px' : '11px 14px',\n            background: 'transparent', color: MUTED, border: '1px solid transparent',\n            borderRadius: 10, fontSize: 14,\n          }} title={collapsed && !isMobile ? 'Sair' : undefined}>\n            <Icon name=\"logout\" size={16} color={MUTED} />\n            {(!collapsed || isMobile) && 'Sair'}\n          <\u002Fbutton>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002F>\n  );\n}\n\n/* ─── APP ───────────────────────────────────── */\nfunction App() {\n  const isMobile = useIsMobile();\n  const [authed, setAuthed] = useState(() => load('nodex_session', false));\n  const [active, setActive] = useState('dashboard');\n  const [collapsed, setCollapsed] = useState(false);\n  const [mobileOpen, setMobileOpen] = useState(false);\n\n  const [services, setServices_] = useState(() => load('nodex_services', [\n    { id: 1, empresa: 'Tech Solutions', descricao: 'Gestão de tráfego pago', value: 3500, status: 'Concluído', date: '2026-01-15' },\n    { id: 2, empresa: 'Bella Moda', descricao: 'Social media + criação de conteúdo', value: 3500, status: 'Em andamento', date: '2026-01-15' },\n    { id: 3, empresa: 'Construtora Prime', descricao: 'SEO + Google Ads', value: 3500, status: 'Concluído', date: '2026-01-15' },\n    { id: 4, empresa: 'Farmácia Popular', descricao: 'Meta Ads', value: 3500, status: 'A fazer', date: '2026-01-15' },\n  ]));\n  const [cashEntries, setCashEntries_] = useState(() => load('nodex_cash', [\n    { id: 1, type: 'Entrada', descricao: 'Recebimento Tech Solutions', value: 3500, date: '2026-01-16' },\n    { id: 2, type: 'Entrada', descricao: 'Recebimento Construtora Prime', value: 3500, date: '2026-01-16' },\n    { id: 3, type: 'Entrada', descricao: 'Ferramentas SaaS', value: 3500, date: '2026-01-16' },\n    { id: 4, type: 'Entrada', descricao: 'Imposto MEI', value: 3500, date: '2026-01-16' },\n  ]));\n\n  const setServices = (v) => { setServices_(v); save('nodex_services', v); };\n  const setCashEntries = (v) => { setCashEntries_(v); save('nodex_cash', v); };\n\n  const login = () => { save('nodex_session', true); setAuthed(true); };\n  const logout = () => { save('nodex_session', false); setAuthed(false); };\n\n  const sidebarWidth = isMobile ? 0 : (collapsed ? 64 : 240);\n\n  if (!authed) return <Login onLogin={login} />;\n\n  return (\n    <div style={{ display: 'flex', minHeight: '100vh' }}>\n      <Sidebar\n        active={active} setActive={setActive} onLogout={logout}\n        collapsed={collapsed} setCollapsed={setCollapsed}\n        mobileOpen={mobileOpen} setMobileOpen={setMobileOpen}\n        isMobile={isMobile}\n      />\n\n      {/* Mobile top bar */}\n      {isMobile && (\n        <div style={{\n          position: 'fixed', top: 0, left: 0, right: 0, height: 56, zIndex: 90,\n          background: '#0D0D0D', borderBottom: `1px solid ${BORDER}`,\n          display: 'flex', alignItems: 'center', padding: '0 16px', gap: 16,\n        }}>\n          <button onClick={() => setMobileOpen(true)} style={{\n            ...btnBase, background: 'transparent', color: TEXT, padding: 8,\n            border: `1px solid ${BORDER}`, borderRadius: 8,\n          }}>\n            <HamburgerIcon open={false} size={18} color={TEXT} />\n          <\u002Fbutton>\n          <div style={{ fontSize: 20, fontWeight: 800 }}>\n            <span style={{ color: TEXT }}>NODE<\u002Fspan><span style={{ color: WINE }}>X<\u002Fspan>\n          <\u002Fdiv>\n        <\u002Fdiv>\n      )}\n\n      <main style={{\n        marginLeft: sidebarWidth,\n        flex: 1,\n        padding: isMobile ? '72px 16px 24px' : '40px 48px',\n        minHeight: '100vh',\n        background: 'transparent',\n        transition: 'margin-left 0.25s ease',\n        minWidth: 0,\n      }}>\n        {active === 'dashboard' && <DashboardSection services={services} cashEntries={cashEntries} isMobile={isMobile} />}\n        {active === 'services' && <ServicesSection services={services} setServices={setServices} isMobile={isMobile} />}\n        {active === 'cash' && <CashSection cashEntries={cashEntries} setCashEntries={setCashEntries} isMobile={isMobile} />}\n      <\u002Fmain>\n    <\u002Fdiv>\n  );\n}\n\nconst root = ReactDOM.createRoot(document.getElementById('root'));\nroot.render(<App />);\n<\u002Fscript>\n\n<style>\n@keyframes spotlight {\n  0% { opacity: 0; transform: translate(-72%, -62%) skewX(-30deg) scale(0.9); }\n  100% { opacity: 1; transform: translate(-50%, -40%) skewX(-30deg) scale(1); }\n}\n.animate-spotlight {\n  animation: spotlight 2s ease forwards;\n}\n@keyframes slideUp {\n  from { transform: translateY(20px); opacity: 0; }\n  to { transform: translateY(0); opacity: 1; }\n}\ninput[type=\"date\"]::-webkit-calendar-picker-indicator {\n  filter: invert(0.5);\n  cursor: pointer;\n}\nselect option { background: #181818; color: #F0EDE8; }\n<\u002Fstyle>\n\n\n<\u002Fbody><\u002Fhtml>"
  </script>
</body>
